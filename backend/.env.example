# =============================================================================
# Phoenix Automações — Variáveis de Ambiente
# cp .env.example .env  →  preencha os valores reais
# =============================================================================

# ─── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://phoenix:senha_forte@localhost:5432/phoenix_automacoes"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:senha_redis@phoenix-redis:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="gere-um-secret-de-64-chars-aqui-000000000000000000000000000000000000000"
JWT_EXPIRES_IN="8h"

# ─── URLs ─────────────────────────────────────────────────────────────────────
APP_URL="https://app.seucliente.com.br"
FRONTEND_URL="https://app.seucliente.com.br"

# ─── Clínica ─────────────────────────────────────────────────────────────────
CLINIC_NAME="Minha Clínica"
CLINIC_WHATSAPP="5551995595300"
CLINIC_TIMEZONE="America/Sao_Paulo"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-..."
OPENAI_MODEL="gpt-4o-mini"

# ─── WhatsApp Provider ───────────────────────────────────────────────────────
# "mock" = logs no console  |  "baileys" = WhatsApp real (futuro)
WHATSAPP_PROVIDER="mock"

# ─── Google Calendar ─────────────────────────────────────────────────────────
# Opção A — Service Account (recomendado para servidor):
#   1. Google Cloud Console → IAM → Service Accounts → Criar
#   2. Baixar JSON da chave e salvar em: ./credentials/google-service-account.json
#   3. Compartilhar o calendário com o e-mail da service account
GOOGLE_SERVICE_ACCOUNT_KEY_FILE="./credentials/google-service-account.json"
GOOGLE_CALENDAR_ID="primary"
# Deixe GOOGLE_ENABLED=false para desabilitar a integração em dev
GOOGLE_ENABLED=false
